rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Contadores ──────────────────────────────────────────────────────────
    match /counters/{counterId} {

      // Cualquiera puede leer un contador público; solo el propietario y
      // usuarios autorizados pueden leer uno privado.
      allow read: if resource.data.isPublic == true
                  || request.auth != null
                     && (request.auth.uid == resource.data.ownerId
                         || request.auth.uid in resource.data.get('authorizedUserIds', []));

      // Solo el propietario o usuarios autorizados pueden crear/actualizar.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;

      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.ownerId
                        || request.auth.uid in resource.data.get('authorizedUserIds', []));

      // Solo el propietario puede borrar.
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;

      // ── Subcoleción de espectadores en directo ────────────────────────────
      // Cualquiera (incluso sin sesión) puede escribir/leer su propio doc de
      // presencia. Solo se permite escribir el campo lastSeen (número).
      match /viewers/{sessionId} {
        allow read: if true;
        allow write: if request.resource.data.keys().hasOnly(['lastSeen'])
                     && request.resource.data.lastSeen is number;
        allow delete: if true;
      }
    }

    // ── Usuarios ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

  }
}
